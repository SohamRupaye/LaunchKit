# Generated by LaunchKit — https://github.com/SohamRupaye/launchkit
# Do not edit manually — run `launchkit generate --only ci` to regenerate

stages:
{% if "test" in steps %}
  - test
{% endif %}
{% if "build" in steps or "push" in steps %}
  - build
{% endif %}

variables:
  REGISTRY: {{ registry }}

{% for svc_name, svc in service_configs.items() %}
{% if "test" in steps %}
test-{{ svc_name }}:
  stage: test
  {% if svc.lang.value == "python" %}
  image: python:3.12-slim
  script:
    - cd services/{{ svc_name }}
    - pip install -r requirements.txt
    - pytest
  {% elif svc.lang.value == "node" %}
  image: node:20-alpine
  script:
    - cd services/{{ svc_name }}
    - npm ci
    - npm test
  {% elif svc.lang.value == "go" %}
  image: golang:1.22-alpine
  script:
    - cd services/{{ svc_name }}
    - go test ./...
  {% endif %}
  {% if affected_only and services | length > 1 %}
  rules:
    - changes:
        - services/{{ svc_name }}/**/*
        - apps/{{ svc_name }}/**/*
  {% endif %}

{% endif %}
{% if "build" in steps %}
build-{{ svc_name }}:
  stage: build
  image: docker:24
  services:
    - docker:24-dind
  variables:
    DOCKER_TLS_CERTDIR: /certs
  before_script:
    - docker login -u $CI_REGISTRY_USER -p ${{ secret }} $CI_REGISTRY
  script:
    - docker build -t $REGISTRY/{{ svc_name }}:$CI_COMMIT_SHA services/{{ svc_name }}
    - docker push $REGISTRY/{{ svc_name }}:$CI_COMMIT_SHA
  {% if affected_only and services | length > 1 %}
  rules:
    - changes:
        - services/{{ svc_name }}/**/*
        - apps/{{ svc_name }}/**/*
  {% endif %}

{% endif %}
{% endfor %}
