# Generated by LaunchKit — https://github.com/SohamRupaye/launchkit
# Do not edit manually — run `launchkit generate --only ci` to regenerate

name: CI

on:
  push:
    branches: [{{ branches | join(', ') }}]
  pull_request:
    branches: [{{ branches | join(', ') }}]

env:
  REGISTRY: {{ registry }}

jobs:
{% if affected_only and services | length > 1 %}
  detect-changes:
    name: Detect changed services
    runs-on: ubuntu-latest
    outputs:
    {% for svc in services %}
      {{ svc }}: ${{ "{{" }} steps.changes.outputs.{{ svc }} {{ "}}" }}
    {% endfor %}
    steps:
      - uses: actions/checkout@v4
      - uses: dorny/paths-filter@v3
        id: changes
        with:
          filters: |
          {% for svc in services %}
            {{ svc }}:
              - '{{ contexts[svc] }}/**'
          {% endfor %}

{% endif %}
{% for svc_name, svc in service_configs.items() %}
  build-{{ svc_name }}:
    name: Build & Push {{ svc_name }}
    runs-on: ubuntu-latest
  {% if affected_only and services | length > 1 %}
    needs: detect-changes
    if: needs.detect-changes.outputs.{{ svc_name }} == 'true'
  {% endif %}
    steps:
      - uses: actions/checkout@v4

      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@v3

      - name: Log in to registry
        uses: docker/login-action@v3
        with:
          registry: {{ registry_host }}
          username: ${{ "{{" }} github.actor {{ "}}" }}
          password: ${{ "{{" }} secrets.{{ secret }} {{ "}}" }}

  {% if "test" in steps %}
    {% if svc.lang.value == "python" %}
      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.12'

      - name: Run tests
        run: |
          cd {{ contexts[svc_name] }}
          pip install -r requirements.txt
          pytest

    {% elif svc.lang.value == "node" %}
      - name: Set up Node
        uses: actions/setup-node@v4
        with:
          node-version: '20'
          cache: 'npm'

      - name: Run tests
        run: |
          cd {{ contexts[svc_name] }}
          npm ci
          npm test

    {% elif svc.lang.value == "go" %}
      - name: Set up Go
        uses: actions/setup-go@v5
        with:
          go-version: '1.22'

      - name: Run tests
        run: |
          cd {{ contexts[svc_name] }}
          go test ./...

    {% elif svc.lang.value == "java" %}
      - name: Set up JDK
        uses: actions/setup-java@v4
        with:
          distribution: 'temurin'
          java-version: '21'
          cache: 'maven'

      - name: Run tests
        run: |
          cd {{ contexts[svc_name] }}
          # Adjust for your build tool (Gradle: ./gradlew test)
          mvn -B test

    {% elif svc.lang.value == "rust" %}
      - name: Set up Rust
        uses: dtolnay/rust-toolchain@stable

      - name: Run tests
        run: |
          cd {{ contexts[svc_name] }}
          cargo test --all

    {% elif svc.lang.value == "ruby" %}
      - name: Set up Ruby
        uses: ruby/setup-ruby@v1
        with:
          ruby-version: '3.3'
          bundler-cache: true

      - name: Run tests
        run: |
          cd {{ contexts[svc_name] }}
          bundle exec rake

    {% elif svc.lang.value == "php" %}
      - name: Set up PHP
        uses: shivammathur/setup-php@v2
        with:
          php-version: '8.3'

      - name: Run tests
        run: |
          cd {{ contexts[svc_name] }}
          composer install --no-interaction --prefer-dist
          vendor/bin/phpunit

    {% elif svc.lang.value == "dotnet" %}
      - name: Set up .NET
        uses: actions/setup-dotnet@v4
        with:
          dotnet-version: '8.0'

      - name: Run tests
        run: |
          cd {{ contexts[svc_name] }}
          dotnet test

    {% endif %}
  {% endif %}
  {% if "verify" in steps %}
      - name: Verify generated deployment (LaunchKit)
        # Proves the generated Dockerfile/manifests/CI are valid before we build
        # and push. Requires launchkit-cli on PyPI.
        run: |
          python3 -m pip install --quiet launchkit-cli
          launchkit verify --level static

  {% endif %}
  {% if "build" in steps %}
      - name: Build and push image
        uses: docker/build-push-action@v5
        with:
          context: {{ contexts[svc_name] }}
          push: ${{ "{{" }} github.ref == 'refs/heads/{{ default_branch }}' {{ "}}" }}
          tags: {{ registry }}/{{ svc_name }}:${{ "{{" }} github.sha {{ "}}" }}
          cache-from: type=gha
          cache-to: type=gha,mode=max

  {% endif %}
{% endfor %}
