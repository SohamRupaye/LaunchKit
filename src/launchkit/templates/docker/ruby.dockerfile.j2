# Generated by LaunchKit — https://github.com/yourname/launchkit
# Ruby{% if framework == "rails" %} on Rails{% endif %} — multi-stage build with Puma

FROM ruby:3.3-slim AS deps
WORKDIR /app

# Install build dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    libpq-dev \
    nodejs \
    && rm -rf /var/lib/apt/lists/*

COPY Gemfile Gemfile.lock ./
RUN bundle config set --local deployment true && \
    bundle config set --local without 'development test' && \
    bundle install --jobs 4

FROM deps AS builder
COPY . .
{% if framework == "rails" %}
# Precompile assets (skip if API-only)
RUN SECRET_KEY_BASE=precompile bundle exec rails assets:precompile 2>/dev/null || true
{% endif %}

FROM ruby:3.3-slim AS runtime
WORKDIR /app

# Install runtime dependencies only
RUN apt-get update && apt-get install -y --no-install-recommends \
    libpq5 \
    nodejs \
    && rm -rf /var/lib/apt/lists/*

# Security: run as non-root
RUN groupadd -r appgroup && useradd -r -g appgroup -d /app appuser
RUN chown -R appuser:appgroup /app
USER appuser

COPY --from=builder /app /app

{% if port %}
EXPOSE {{ port }}
{% endif %}

{% if framework == "rails" %}
ENV RAILS_ENV=production \
    RAILS_LOG_TO_STDOUT=true \
    RAILS_SERVE_STATIC_FILES=true

CMD ["bundle", "exec", "puma", "-C", "config/puma.rb"]
{% else %}
CMD ["bundle", "exec", "ruby", "app.rb"]
{% endif %}
